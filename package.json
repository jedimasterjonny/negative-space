{
	"name": "negative-space",
	"private": true,
	"engines": {
		"node": ">=20"
	},
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
